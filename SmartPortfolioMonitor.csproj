    <UserSecretsId>6c5e3f62-2042-407d-83d2-109498466a55</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.OpenApi" Version="10.0.3" />
